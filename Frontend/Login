<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login | Clinic of AI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,700&amp;family=Manrope:wght@400;600&amp;family=Space+Grotesk:wght@400;600&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-high": "#f5e6d3",
                        "on-background": "#221a0f",
                        "surface-container-low": "#fff2e2",
                        "primary-container": "#002a2e",
                        "error": "#ba1a1a",
                        "on-primary-fixed": "#001f23",
                        "on-secondary": "#ffffff",
                        "tertiary-container": "#12263a",
                        "on-primary-container": "#009ba7",
                        "primary-fixed": "#87f3ff",
                        "outline-variant": "#c4c6cd",
                        "on-error-container": "#93000a",
                        "tertiary": "#001022",
                        "on-tertiary-fixed": "#071d30",
                        "on-tertiary": "#ffffff",
                        "surface-bright": "#fff8f3",
                        "surface-container-highest": "#efe0cd",
                        "on-error": "#ffffff",
                        "surface-variant": "#efe0cd",
                        "background": "#fff8f3",
                        "tertiary-fixed-dim": "#b5c8e2",
                        "secondary-fixed-dim": "#ffb694",
                        "outline": "#74777d",
                        "on-secondary-container": "#622400",
                        "on-surface-variant": "#43474c",
                        "surface-dim": "#e6d8c5",
                        "inverse-surface": "#372f22",
                        "secondary": "#a14000",
                        "on-surface": "#221a0f",
                        "inverse-on-surface": "#feefdb",
                        "secondary-container": "#ff7a32",
                        "on-tertiary-fixed-variant": "#35485e",
                        "on-tertiary-container": "#7a8ea6",
                        "on-primary": "#ffffff",
                        "primary": "#001215",
                        "on-primary-fixed-variant": "#004f55",
                        "inverse-primary": "#59d8e5",
                        "on-secondary-fixed-variant": "#7b2f00",
                        "surface-container-lowest": "#ffffff",
                        "secondary-fixed": "#ffdbcc",
                        "surface-tint": "#006971",
                        "surface": "#fff8f3",
                        "on-secondary-fixed": "#351000",
                        "error-container": "#ffdad6",
                        "tertiary-fixed": "#d0e4ff",
                        "surface-container": "#fbecd9",
                        "primary-fixed-dim": "#59d8e5"
                    },
                    fontFamily: {
                        "headline": ["Newsreader", "serif"],
                        "body": ["Manrope", "sans-serif"],
                        "label": ["Space Grotesk", "monospace"]
                    },
                    borderRadius: { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .grid-pattern {
            background-image: radial-gradient(#001215 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.05;
        }

        .circuit-mask {
            mask-image: linear-gradient(to right, black, transparent);
        }
    </style>
</head>

<body
    class="bg-surface font-body text-on-surface selection:bg-secondary-container selection:text-on-secondary-container">
    <main class="min-h-screen flex flex-col md:flex-row overflow-hidden relative">
        <!-- Brand Watermark Background -->
        <div class="absolute inset-0 grid-pattern pointer-events-none"></div>
        <!-- Left Column: Visual Identity (Split-screen drawing) -->
        <div
            class="hidden md:flex md:w-1/2 lg:w-3/5 bg-tertiary-container relative items-center justify-center overflow-hidden border-r border-outline-variant/10">
            <div class="absolute inset-0 opacity-20">
                <div class="absolute inset-0 bg-gradient-to-br from-primary via-tertiary to-secondary/20"></div>
                <!-- Abstract Technical Pattern Replacement -->
                <img alt="Abstract technical circuit architectural blueprint with orange glow"
                    class="w-full h-full object-cover mix-blend-overlay"
                    data-alt="Intricate digital circuit board with architectural layout lines"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuDffKmNi73PZ3eBFDnRXIIJljlSgEQVs8s81pYMp1V87xs8oJgFxL-Vh09EFh0dVRj6Nt8c5SeZRLGjcaqyKvf_K-jxcLlsjzdZPXqtuJ0PByG6VI3SAl4WeFb81TI_wuQkFxcV9A9K56VTFgalo9uVG-IpBAV5RNp0ElUhpmEenpm07GyFeyKjNBkhcu6B35HOR3pmXlrImfql7dPBqMfaITnJ1l_KjYJDkvBDb6BZVDd4P4WbRR0RdP-DavCNTqWXmxW_vlS2Sxk" />
            </div>
            <div class="relative z-10 p-12 max-w-xl">
                <div class="mb-8 flex items-center gap-3">
                    <span class="w-12 h-[1px] bg-secondary-container"></span>
                    <span class="font-label text-xs tracking-[0.2em] text-secondary-container uppercase">Systems
                        Architected</span>
                </div>
                <h1 class="font-headline text-5xl lg:text-7xl text-surface-bright leading-tight font-bold mb-6">
                    Resume Your <br /><span class="italic text-secondary-container">Architecture.</span>
                </h1>
                <p class="text-surface-variant/70 text-lg font-light leading-relaxed max-w-md">
                    Access the foundational layers of your intelligent systems. Precision-guided cognition awaits.
                </p>
            </div>
            <!-- Decorative Hex Grid Element -->
            <div class="absolute bottom-[-10%] right-[-5%] opacity-10">
                <span class="material-symbols-outlined text-[30rem] text-surface-bright">architecture</span>
            </div>
        </div>
        <!-- Right Column: Login Form -->
        <div
            class="flex-1 flex flex-col items-center justify-center p-8 md:p-16 lg:p-24 relative z-10 bg-surface/80 backdrop-blur-sm">
            <div class="w-full max-w-md">
                <!-- Mobile Branding -->
                <div class="md:hidden mb-12 flex flex-col items-center">
                    <div class="font-headline text-2xl font-bold tracking-widest text-primary uppercase">Clinic of AI
                    </div>
                    <div class="h-1 w-8 bg-secondary mt-2"></div>
                </div>
                <header class="mb-10">
                    <h2 class="font-headline text-3xl font-bold text-primary mb-2">Welcome Back</h2>
                    <p class="text-on-surface-variant font-body">Sign in to manage your intelligence modules.</p>
                </header>
                <form class="space-y-6">
                    <!-- Email Field -->
                    <div class="space-y-2 group">
                        <label
                            class="font-label text-xs tracking-widest text-on-surface-variant uppercase flex items-center gap-2"
                            for="email">
                            <span class="material-symbols-outlined text-sm">alternate_email</span>
                            Email Address
                        </label>
                        <input
                            class="w-full bg-surface-container-low border-b-2 border-outline-variant/30 focus:border-secondary-container focus:ring-0 transition-colors py-3 px-1 text-on-surface placeholder:text-outline-variant/50"
                            id="email" placeholder="architect@clinic.ai" required="" type="email" />
                    </div>
                    <!-- Password Field -->
                    <div class="space-y-2 group">
                        <div class="flex justify-between items-center">
                            <label
                                class="font-label text-xs tracking-widest text-on-surface-variant uppercase flex items-center gap-2"
                                for="password">
                                <span class="material-symbols-outlined text-sm">shield_lock</span>
                                Access Key
                            </label>
                            <a class="font-label text-[10px] tracking-widest text-secondary hover:text-on-secondary-container transition-colors uppercase"
                                href="#">Forgot?</a>
                        </div>
                        <div class="relative">
                            <input
                                class="w-full bg-surface-container-low border-b-2 border-outline-variant/30 focus:border-secondary-container focus:ring-0 transition-colors py-3 px-1 text-on-surface placeholder:text-outline-variant/50"
                                id="password" placeholder="••••••••••••" required="" type="password" />
                            <button
                                class="absolute right-2 top-1/2 -translate-y-1/2 text-outline-variant hover:text-primary"
                                type="button">
                                <span class="material-symbols-outlined text-sm">visibility</span>
                            </button>
                        </div>
                    </div>
                    <!-- Actions -->
                    <div class="pt-4 space-y-4">
                        <button
                            class="w-full bg-secondary hover:bg-on-secondary-container text-on-secondary font-label py-4 px-6 rounded-lg transition-all flex items-center justify-center gap-3 tracking-widest uppercase text-sm group"
                            type="submit">
                            Login to Console
                            <span
                                class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </button>
                        <div class="relative flex items-center py-4">
                            <div class="flex-grow border-t border-outline-variant/20"></div>
                            <span
                                class="flex-shrink mx-4 font-label text-[10px] text-outline tracking-widest uppercase">OR
                                VERIFY VIA</span>
                            <div class="flex-grow border-t border-outline-variant/20"></div>
                        </div>
                        <button
                            class="w-full bg-surface-container-highest hover:bg-surface-container-high border border-outline-variant/10 text-primary font-label py-4 px-6 rounded-lg transition-all flex items-center justify-center gap-3 tracking-widest uppercase text-sm"
                            type="button">
                            <img alt="Google" class="w-5 h-5" data-alt="Google logo icon"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuD9WiA8wn_oJhk-NkiXEybhZoK0SpsseShHa-pOcjHIO3lsAYhuftpk6kXyhN5Tw2XLGMgkAr89pay2Kehi7fNoABFiAjCZ3Uu2AGam_sY7PMIu4jzorZQ-sUFUTLJmMwM_zkm647Ebeu3HGF81TmwACBoxqIgxYeKQ9CKnZfs4j26mD5g53Dxebqp43jMvMaWHA0WIHMt6aEeqdYTCfnfjU_gPRaR4vdBbPOjpMXezq4-uJWC_u0mPsmRDomWrd6NWeyyX_TbW7_8" />
                            Sign in with Google
                        </button>
                    </div>
                </form>
                <footer class="mt-12 text-center">
                    <p class="font-body text-sm text-on-surface-variant">
                        New system operator?
                        <a class="text-secondary font-semibold hover:underline decoration-2 underline-offset-4"
                            href="#">Request Access</a>
                    </p>
                </footer>
            </div>
        </div>
        <!-- Decorative Floating Elements -->
        <div class="fixed bottom-8 right-8 pointer-events-none opacity-20 md:opacity-100">
            <div class="bg-surface-container-low p-4 border border-outline-variant/20 flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-secondary animate-pulse"></div>
                <div class="font-label text-[10px] tracking-widest text-primary uppercase">Status: Core Online</div>
            </div>
        </div>
    </main>
    <!-- Simple Footer for Legal -->
    <footer
        class="bg-[#fff2e2] dark:bg-[#001022] w-full py-8 mt-auto flex flex-col md:flex-row justify-between items-center px-8 gap-4 border-t border-outline-variant/5">
        <div class="font-mono text-[10px] tracking-widest text-[#001215] dark:text-[#fff8f3] uppercase opacity-70">
            © 2024 Clinic of AI. Systems Architected.
        </div>
        <div class="flex gap-6">
            <a class="font-mono text-[10px] tracking-widest text-[#001215] dark:text-[#fff8f3] uppercase opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                href="#">Privacy Policy</a>
            <a class="font-mono text-[10px] tracking-widest text-[#001215] dark:text-[#fff8f3] uppercase opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                href="#">Terms of Service</a>
            <a class="font-mono text-[10px] tracking-widest text-[#001215] dark:text-[#fff8f3] uppercase opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                href="#">Security Architecture</a>
        </div>
    </footer>
</body>

</html>