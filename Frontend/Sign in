<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Clinic of AI - Initiate Your Node</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&amp;family=Manrope:wght@200..800&amp;family=Space+Grotesk:wght@300..700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-high": "#f5e6d3",
                        "on-background": "#221a0f",
                        "surface-container-low": "#fff2e2",
                        "primary-container": "#002a2e",
                        "error": "#ba1a1a",
                        "on-primary-fixed": "#001f23",
                        "on-secondary": "#ffffff",
                        "tertiary-container": "#12263a",
                        "on-primary-container": "#009ba7",
                        "primary-fixed": "#87f3ff",
                        "outline-variant": "#c4c6cd",
                        "on-error-container": "#93000a",
                        "tertiary": "#001022",
                        "on-tertiary-fixed": "#071d30",
                        "on-tertiary": "#ffffff",
                        "surface-bright": "#fff8f3",
                        "surface-container-highest": "#efe0cd",
                        "on-error": "#ffffff",
                        "surface-variant": "#efe0cd",
                        "background": "#fff8f3",
                        "tertiary-fixed-dim": "#b5c8e2",
                        "secondary-fixed-dim": "#ffb694",
                        "outline": "#74777d",
                        "on-secondary-container": "#622400",
                        "on-surface-variant": "#43474c",
                        "surface-dim": "#e6d8c5",
                        "inverse-surface": "#372f22",
                        "secondary": "#a14000",
                        "on-surface": "#221a0f",
                        "inverse-on-surface": "#feefdb",
                        "secondary-container": "#ff7a32",
                        "on-tertiary-fixed-variant": "#35485e",
                        "on-tertiary-container": "#7a8ea6",
                        "on-primary": "#ffffff",
                        "primary": "#001215",
                        "on-primary-fixed-variant": "#004f55",
                        "inverse-primary": "#59d8e5",
                        "on-secondary-fixed-variant": "#7b2f00",
                        "surface-container-lowest": "#ffffff",
                        "secondary-fixed": "#ffdbcc",
                        "surface-tint": "#006971",
                        "surface": "#fff8f3",
                        "on-secondary-fixed": "#351000",
                        "error-container": "#ffdad6",
                        "tertiary-fixed": "#d0e4ff",
                        "surface-container": "#fbecd9",
                        "primary-fixed-dim": "#59d8e5"
                    },
                    fontFamily: {
                        "headline": ["Newsreader"],
                        "body": ["Manrope"],
                        "label": ["Space Grotesk"]
                    },
                    borderRadius: { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem" },
                },
            },
        }
    </script>
    <style>
        .grid-watermark {
            background-image: radial-gradient(circle, #00121510 1px, transparent 1px);
            background-size: 24px 24px;
        }

        .circuit-accent {
            background: linear-gradient(90deg, transparent 0%, #a1400020 50%, transparent 100%);
            height: 1px;
            width: 100%;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background text-on-background font-body min-h-screen flex flex-col">
    <!-- TopAppBar (Shared Component Logic: Suppressed for Transactional Page) -->
    <main class="flex-grow flex flex-col lg:flex-row min-h-screen overflow-hidden">
        <!-- Left Side: Editorial Branding & Imagery -->
        <section
            class="lg:w-1/2 relative bg-primary overflow-hidden flex flex-col justify-between p-12 lg:p-24 border-r border-outline-variant/10">
            <!-- Grid Background Overlay -->
            <div class="absolute inset-0 grid-watermark opacity-20 pointer-events-none"></div>
            <!-- Branding -->
            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-16">
                    <span class="material-symbols-outlined text-secondary-container text-4xl" data-icon="hub">hub</span>
                    <h1 class="font-headline font-bold text-2xl text-surface uppercase tracking-widest">Clinic of AI
                    </h1>
                </div>
                <div class="max-w-md">
                    <span class="font-label text-secondary-container tracking-widest text-sm mb-4 block">SYSTEMS
                        ARCHITECTED</span>
                    <h2 class="font-headline text-5xl lg:text-7xl text-surface leading-tight mb-8">Initiate Your Node.
                    </h2>
                    <p class="text-surface-variant font-light text-lg leading-relaxed">
                        Join the architectural avant-garde. Secure your position within the global neural infrastructure
                        of premium intelligence.
                    </p>
                </div>
            </div>
            <!-- Decorative Visual -->
            <div class="relative z-10 mt-12">
                <div class="w-full h-[300px] rounded-xl overflow-hidden shadow-2xl relative group">
                    <img alt="Architectural circuit blueprint visualization"
                        class="w-full h-full object-cover grayscale opacity-60 mix-blend-luminosity"
                        data-alt="Digital architectural blueprints with glowing orange nodes"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYNhB6m-qmpKYCjUfrdWqmJr9uWUIiVjm9mWxoAiwrwFasqcLi0vudpNJof2MhJMbTGnDKQJ_FlLa9DLlD66S5H4hh57smCGX9aq87ZrOV4mfTxeK07q8ivjH5MkPvP-V1Ns-dwdvXFNLgDFpEzx8AeN0iG_4tXfAvjyPJkYVswZRy1MB7CALCLRtVV2Qq0s52s0Y60jh5JeDbkhJc-QH9ZxdvSt_Htqr23NyY6-jR-14Qp3o0q7jAbgUsLBwTtMFomYDn_q2BgS4" />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-primary via-transparent to-transparent opacity-80">
                    </div>
                    <!-- Hexagonal Brand Mark -->
                    <div
                        class="absolute bottom-6 right-6 w-12 h-12 bg-secondary-container flex items-center justify-center [clip-path:polygon(25%_0%,75%_0%,100%_50%,75%_100%,25%_100%,0%_50%)]">
                        <span class="material-symbols-outlined text-primary text-xl" data-icon="architecture"
                            style="font-variation-settings: 'FILL' 1;">architecture</span>
                    </div>
                </div>
            </div>
        </section>
        <!-- Right Side: Sign-Up Form -->
        <section class="lg:w-1/2 bg-surface flex items-center justify-center p-8 lg:p-24 relative">
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-surface-container-high rounded-full blur-[100px] opacity-50 -mr-32 -mt-32">
            </div>
            <div class="w-full max-w-md relative z-10">
                <div class="mb-12">
                    <h3 class="font-headline text-3xl text-primary mb-2">Registration Protocol</h3>
                    <p class="text-on-surface-variant font-light">Input your credentials to access the internal clinic
                        environment.</p>
                </div>
                <form class="space-y-6">
                    <!-- Full Name -->
                    <div class="relative group">
                        <label
                            class="font-label text-xs tracking-widest text-on-surface-variant uppercase mb-2 block">Identity
                            (Full Name)</label>
                        <input
                            class="w-full bg-surface-container-low border-b border-outline-variant/30 border-t-0 border-x-0 px-0 py-3 focus:ring-0 focus:border-on-primary-container transition-all placeholder:text-outline/40 text-primary"
                            placeholder="Alexander Vellum" type="text" />
                    </div>
                    <!-- Company -->
                    <div class="relative group">
                        <label
                            class="font-label text-xs tracking-widest text-on-surface-variant uppercase mb-2 block">Institution
                            / Company</label>
                        <input
                            class="w-full bg-surface-container-low border-b border-outline-variant/30 border-t-0 border-x-0 px-0 py-3 focus:ring-0 focus:border-on-primary-container transition-all placeholder:text-outline/40 text-primary"
                            placeholder="Neural Dynamics Ltd." type="text" />
                    </div>
                    <!-- Email -->
                    <div class="relative group">
                        <label
                            class="font-label text-xs tracking-widest text-on-surface-variant uppercase mb-2 block">Digital
                            Uplink (Email)</label>
                        <input
                            class="w-full bg-surface-container-low border-b border-outline-variant/30 border-t-0 border-x-0 px-0 py-3 focus:ring-0 focus:border-on-primary-container transition-all placeholder:text-outline/40 text-primary"
                            placeholder="architect@clinic.ai" type="email" />
                    </div>
                    <!-- Password -->
                    <div class="relative group">
                        <label
                            class="font-label text-xs tracking-widest text-on-surface-variant uppercase mb-2 block">Access
                            Key (Password)</label>
                        <input
                            class="w-full bg-surface-container-low border-b border-outline-variant/30 border-t-0 border-x-0 px-0 py-3 focus:ring-0 focus:border-on-primary-container transition-all placeholder:text-outline/40 text-primary"
                            placeholder="••••••••••••" type="password" />
                    </div>
                    <!-- TOS Checkbox -->
                    <div class="flex items-start gap-3 py-2">
                        <input
                            class="mt-1 rounded-sm border-outline-variant text-secondary focus:ring-secondary cursor-pointer"
                            id="tos" type="checkbox" />
                        <label class="text-sm text-on-surface-variant leading-tight cursor-pointer" for="tos">
                            I agree to the <a class="text-secondary hover:underline" href="#">Terms of Service</a> and
                            the <a class="text-secondary hover:underline" href="#">Neural Privacy Protocol</a>.
                        </label>
                    </div>
                    <!-- Submit Button -->
                    <button
                        class="w-full bg-secondary text-on-secondary py-5 rounded-lg font-label font-bold tracking-[0.2em] uppercase text-sm hover:bg-secondary/90 transition-all flex items-center justify-center gap-4 group"
                        type="submit">
                        Create Account
                        <span class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-1"
                            data-icon="arrow_forward">arrow_forward</span>
                    </button>
                </form>
                <!-- Footer Link -->
                <div class="mt-12 text-center">
                    <p class="text-on-surface-variant text-sm">
                        Already have an account?
                        <a class="font-label text-primary font-bold tracking-wider hover:text-secondary transition-colors ml-2 uppercase text-xs"
                            href="#">Login</a>
                    </p>
                </div>
            </div>
        </section>
    </main>
    <!-- Footer (Shared Component Logic) -->
    <footer class="bg-[#fff2e2] dark:bg-[#001022] w-full py-8 mt-auto tonal shift via surface-container-low">
        <div class="flex flex-col md:flex-row justify-between items-center px-8 gap-4 max-w-7xl mx-auto">
            <p
                class="font-mono text-[10px] tracking-widest Space Grotesk uppercase text-[#001215] dark:text-[#fff8f3] opacity-70">
                © 2024 Clinic of AI. Systems Architected.
            </p>
            <div class="flex gap-8">
                <a class="font-mono text-[10px] tracking-widest Space Grotesk uppercase text-[#001215] dark:text-[#fff8f3] opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                    href="#">Privacy Policy</a>
                <a class="font-mono text-[10px] tracking-widest Space Grotesk uppercase text-[#001215] dark:text-[#fff8f3] opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                    href="#">Terms of Service</a>
                <a class="font-mono text-[10px] tracking-widest Space Grotesk uppercase text-[#001215] dark:text-[#fff8f3] opacity-70 hover:opacity-100 hover:text-[#a14000] transition-colors"
                    href="#">Security Architecture</a>
            </div>
        </div>
    </footer>
</body>

</html>