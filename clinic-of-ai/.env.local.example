# Supabase
# Found in: Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend
# Found in: resend.com -> API Keys
RESEND_API_KEY=re_YOUR_KEY

# Email addresses
# The "from" address must be a verified domain in Resend
RESEND_FROM_EMAIL=hello@clinicofai.com
PHILIPPE_EMAIL=philippe@clinicofai.com

# Public site URL (used for canonical/SEO metadata)
NEXT_PUBLIC_SITE_URL=https://clinicofai.com

# Optional analytics
# Set GA4 measurement id (example: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Set Plausible domain (example: clinicofai.com)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# true (default): require consent before analytics
# false: analytics starts immediately
NEXT_PUBLIC_ANALYTICS_REQUIRE_CONSENT=true
